<!-- ======= Vision Section ======= -->
<section class="vision section-bg" id="vision">
<div class="container" data-aos="fade-up">
<div class="row justify-content-around gy-4">
<div class="col-lg-6 img-bg" data-aos="zoom-in" data-aos-delay="100" style="background-image: url(assets/img/vision.png)"></div>
<div class="col-lg-5 d-flex flex-column justify-content-center">
