<script data-injected="projects-readmore">
document.querySelectorAll('.read-more-btn').forEach(btn => {
  const card = btn.closest('.project-card');
  const extra = card ? card.querySelector('.project-extra') : null;
  // Init ARIA
  btn.setAttribute('aria-expanded', card && card.classList.contains('open') ? 'true' : 'false');
  btn.setAttribute('aria-controls', extra ? (extra.id || '') : '');
  if (extra && !extra.id) {
    extra.id = 'extra-' + Math.random().toString(36).slice(2,8);
    btn.setAttribute('aria-controls', extra.id);
  }
  // Ensure collapsed height
  if (extra) {
    extra.style.maxHeight = card && card.classList.contains('open') ? extra.scrollHeight + 'px' : '0px';
  }
  btn.addEventListener('click', () => {
    if (!card || !extra) return;
    const isOpen = card.classList.toggle('open');
    btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    if (isOpen) {
      extra.style.display = 'block';
      requestAnimationFrame(() => {
        extra.style.maxHeight = extra.scrollHeight + 'px';
      });
    } else {
      extra.style.maxHeight = extra.scrollHeight + 'px'; // set to current to kick off transition
      requestAnimationFrame(() => {
        extra.style.maxHeight = '0px';
      });
      // Hide after transition ends for better a11y
      extra.addEventListener('transitionend', function handler(e) {
        if (!card.classList.contains('open')) {
          extra.style.display = 'none';
        }
        extra.removeEventListener('transitionend', handler);
      });
    }
  });
});
</script></body>
</html>
